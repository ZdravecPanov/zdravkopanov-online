---
---

<header class="navbar-shell">
  <nav class="navbar" aria-label="Primary">
    <a class="navbar__logo" href="/">Built to Monitor. Driven to Maintain.</a>

    <button class="navbar__toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul class="navbar__menu">
      <li><a href="/">Home</a></li>
      <li><a href="/projects/">Projects</a></li>
      <li><a href="https://www.linkedin.com/in/zdravko-panov" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
    </ul>
  </nav>
</header>

<script is:inline>
  const toggle = document.querySelector('.navbar__toggle');
  const menu = document.querySelector('.navbar__menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  }
</script>

<style>
  .navbar-shell {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 50;
    backdrop-filter: blur(16px);
    background: linear-gradient(120deg, rgba(3, 7, 18, 0.82), rgba(3, 10, 18, 0.65));
    border-bottom: 1px solid rgba(45, 212, 191, 0.2);
  }

  .navbar {
    width: 100%;
    max-width: none;
    margin: 0;
    padding: 0.85rem 1.5rem 0.85rem calc(clamp(1rem, 7vw, 6rem) + 1.5rem);
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 1rem;
    color: #e2e8f0;
    position: relative;
  }

  .navbar__logo {
    margin-right: auto;
    text-decoration: none;
    color: #67e8f9;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
  }

  .navbar__menu {
    margin: 0 0 0 auto;
    padding: 0;
    list-style: none;
    display: flex;
    gap: 0.5rem;
  }

  .navbar__menu a {
    color: #e2e8f0;
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.5rem 0.85rem;
    border-radius: 0.5rem;
    border: 1px solid transparent;
    transition: border-color 120ms ease, transform 120ms ease, color 120ms ease;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .navbar__menu a:hover,
  .navbar__menu a:focus-visible {
    color: #5eead4;
    border-color: rgba(94, 234, 212, 0.4);
    transform: translateY(-1px);
  }

  .navbar__toggle {
    display: none;
    border: 1px solid rgba(148, 163, 184, 0.45);
    background: rgba(15, 23, 42, 0.6);
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.5rem;
    padding: 0.55rem 0.6rem;
    color: inherit;
    gap: 0.22rem;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .navbar__toggle span {
    display: block;
    width: 1.2rem;
    height: 2px;
    background: #e2e8f0;
    border-radius: 999px;
  }

  @media (max-width: 980px) {
    .navbar {
      padding: 0.75rem 1rem;
    }
  }

  @media (max-width: 780px) {
    .navbar__toggle {
      display: inline-flex;
    }

    .navbar__menu {
      position: absolute;
      top: 100%;
      left: 0.75rem;
      right: 0.75rem;
      background: rgba(2, 6, 12, 0.94);
      border: 1px solid rgba(45, 212, 191, 0.2);
      border-radius: 0.75rem;
      padding: 0.55rem;
      display: none;
      flex-direction: column;
      gap: 0.3rem;
      backdrop-filter: blur(8px);
    }

    .navbar__menu li {
      width: 100%;
    }

    .navbar__menu a {
      display: block;
      padding: 0.68rem 0.8rem;
    }

    .navbar__menu.is-open {
      display: flex;
    }
  }
</style>


