---
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

const groupedProjects = projects.reduce((acc, project) => {
  const category = project.data.category || 'Other';
  if (!acc[category]) acc[category] = [];
  acc[category].push(project);
  return acc;
}, {} as Record<string, typeof projects>);

const categoryOrder = ['Monitoring', 'Infrastructure', 'Automation'];
const categories = [
  ...categoryOrder.filter((category) => groupedProjects[category]?.length),
  ...Object.keys(groupedProjects).filter((category) => !categoryOrder.includes(category)),
];
---

<section class="projects" id="projects">
  <div class="projects__inner">
    <p class="projects__eyebrow">Case Studies</p>
    <h2 class="projects__title">Projects</h2>

    <div class="projects__controls" aria-label="Project category filters">
      <div class="projects__tabs" role="tablist" aria-label="Project categories">
        <button class="projects__tab" type="button" data-category="All" role="tab" aria-selected="false">All</button>
        {
          categories.map((category) => (
            <button
              class="projects__tab"
              type="button"
              data-category={category}
              role="tab"
              aria-selected={category === 'Monitoring' ? 'true' : 'false'}
            >
              {category}
            </button>
          ))
        }
      </div>

      <label class="projects__select-wrap">
        <span class="sr-only">Choose category</span>
        <select class="projects__select" aria-label="Choose project category">
          <option value="All">All</option>
          {categories.map((category) => <option value={category} selected={category === 'Monitoring'}>{category}</option>)}
        </select>
      </label>
    </div>

    {
      categories.map((category) => (
        <div class="projects__category" data-category-section={category}>
          <h3 class="projects__category-title">{category}</h3>
          <div class="projects__grid">
            {groupedProjects[category].map((project) => (
              <article class="project-card">
                <h4 class="project-card__title">
                  <a class="project-card__title-link" href={`/projects/${project.slug}`}>{project.data.title}</a>
                </h4>
                <p class="project-card__description">{project.data.description}</p>
                <ul class="project-card__tags" aria-label="Tech stack">
                  {project.data.stack.map((tag) => <li>{tag}</li>)}
                </ul>
                <a class="project-card__link" href={`/projects/${project.slug}`}>Open Project</a>
              </article>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector('#projects');
    if (!root) return;

    const sections = Array.from(root.querySelectorAll('[data-category-section]'));
    const tabs = Array.from(root.querySelectorAll('.projects__tab'));
    const select = root.querySelector('.projects__select');

    const setActive = (category) => {
      sections.forEach((section) => {
        const sectionCategory = section.getAttribute('data-category-section');
        const visible = category === 'All' || sectionCategory === category;
        section.hidden = !visible;
      });

      tabs.forEach((tab) => {
        const active = tab.getAttribute('data-category') === category;
        tab.classList.toggle('is-active', active);
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
      });

      if (select && select.value !== category) {
        select.value = category;
      }
    };

    const defaultCategory = 'Monitoring';
    setActive(defaultCategory);

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const category = tab.getAttribute('data-category') || 'All';
        setActive(category);
      });
    });

    if (select) {
      select.addEventListener('change', () => {
        setActive(select.value || 'All');
      });
    }
  })();
</script>

<style>
  .projects {
    padding: 5rem 1.5rem;
    background:
      radial-gradient(circle at 82% 12%, rgba(6, 182, 212, 0.16), transparent 35%),
      radial-gradient(circle at 10% 88%, rgba(16, 185, 129, 0.12), transparent 35%),
      linear-gradient(150deg, #02070d 0%, #070f17 45%, #02070d 100%);
    color: #e2e8f0;
  }

  .projects__inner {
    max-width: 1360px;
    margin: 0 auto;
  }

  .projects__eyebrow {
    display: inline-block;
    margin: 0 0 1rem;
    padding: 0.35rem 0.8rem;
    border: 1px solid rgba(20, 184, 166, 0.45);
    border-radius: 999px;
    color: #5eead4;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.75rem;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
  }

  .projects__title {
    margin: 0 0 1.5rem;
    font-size: clamp(1.9rem, 4.2vw, 2.9rem);
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
    color: #f8fafc;
    letter-spacing: -0.02em;
  }

  .projects__controls {
    margin-bottom: 1.5rem;
  }

  .projects__tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .projects__tab {
    border: 1px solid rgba(100, 116, 139, 0.45);
    background: rgba(2, 6, 12, 0.65);
    color: #cbd5e1;
    border-radius: 999px;
    padding: 0.45rem 0.85rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
    cursor: pointer;
    transition: border-color 140ms ease, color 140ms ease, background 140ms ease;
  }

  .projects__tab:hover,
  .projects__tab:focus-visible {
    color: #e2e8f0;
    border-color: rgba(103, 232, 249, 0.55);
  }

  .projects__tab.is-active {
    color: #022c32;
    border-color: rgba(45, 212, 191, 0.85);
    background: linear-gradient(120deg, #5eead4, #67e8f9);
  }

  .projects__select-wrap {
    display: none;
  }

  .projects__select {
    width: 100%;
    margin-top: 0.5rem;
    border: 1px solid rgba(100, 116, 139, 0.45);
    background: rgba(2, 6, 12, 0.8);
    color: #e2e8f0;
    border-radius: 0.6rem;
    padding: 0.62rem 0.7rem;
    font-size: 0.84rem;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
  }

  .projects__category {
    margin-top: 1.6rem;
  }

  .projects__category-title {
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.28);
    color: #67e8f9;
    font-size: 1.08rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
  }

  .projects__grid {
    display: grid;
    gap: 1.2rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .project-card {
    border: 1px solid rgba(100, 116, 139, 0.35);
    border-radius: 0.9rem;
    background: rgba(2, 6, 12, 0.65);
    backdrop-filter: blur(2px);
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    min-height: 100%;
    transition: transform 140ms ease, border-color 140ms ease, box-shadow 140ms ease;
  }

  .project-card:hover,
  .project-card:focus-within {
    transform: translateY(-3px);
    border-color: rgba(34, 211, 238, 0.55);
    box-shadow: 0 12px 28px rgba(3, 7, 18, 0.45);
  }

  .project-card__title {
    margin: 0 0 0.75rem;
    font-size: 1.15rem;
    line-height: 1.25;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
  }

  .project-card__title-link {
    color: #e2e8f0;
    text-decoration: none;
    font-weight: 700;
    transition: color 140ms ease, font-weight 140ms ease;
  }

  .project-card:hover .project-card__title-link,
  .project-card:focus-within .project-card__title-link,
  .project-card__title-link:hover,
  .project-card__title-link:focus-visible {
    color: #f8fafc;
    font-weight: 800;
  }

  .project-card__description {
    margin: 0;
    flex: 1;
    color: #9ca3af;
    line-height: 1.55;
    font-size: 0.98rem;
    font-family: "Inter", "Segoe UI", system-ui, -apple-system, sans-serif;
  }

  .project-card__tags {
    list-style: none;
    margin: 1rem 0;
    padding: 0;
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .project-card__tags li {
    font-size: 0.75rem;
    border: 1px solid rgba(56, 189, 248, 0.35);
    color: #67e8f9;
    border-radius: 999px;
    padding: 0.25rem 0.65rem;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
  }

  .project-card__link {
    margin-top: auto;
    align-self: flex-start;
    text-decoration: none;
    padding: 0.62rem 1rem;
    border-radius: 0.55rem;
    border: 1px solid rgba(45, 212, 191, 0.45);
    color: #ecfeff;
    background: rgba(6, 182, 212, 0.12);
    font-size: 0.86rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
    transition: transform 140ms ease, border-color 140ms ease, background 140ms ease;
  }

  .project-card__link:hover,
  .project-card__link:focus-visible {
    transform: translateY(-2px);
    border-color: #7dd3fc;
    background: rgba(125, 211, 252, 0.2);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 980px) {
    .projects__inner {
      margin: 0 auto;
      padding-right: 0;
    }
  }

  @media (max-width: 760px) {
    .projects__tabs {
      display: none;
    }

    .projects__select-wrap {
      display: block;
    }
  }

  @media (max-width: 640px) {
    .projects {
      padding-top: 3.5rem;
      padding-bottom: 3.5rem;
    }

    .project-card {
      padding: 1rem;
    }
  }
</style>





