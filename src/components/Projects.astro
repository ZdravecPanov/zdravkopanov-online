---
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

const completedSlugs = [
  'cyberops-portal-securitypulse',
  'prometheus-grafana-monitoring',
  'windows-security-monitoring',
  'zabbix-grafana-monitoring',
  'grafana-html-mail-relay',
  'service-alert-centralization',
];

const ongoingSlugs = [
  'mikrotik-openvpn-remote-access',
  'windows-server-management',
  'powershell-automation',
  'vmware-environment-setup',
];

const bySlug = new Map(projects.map((project) => [project.slug, project]));

const pickBySlug = (slugs: string[]) => slugs
  .map((slug) => bySlug.get(slug))
  .filter(Boolean) as typeof projects;

const completedProjects = pickBySlug(completedSlugs);
const ongoingProjects = pickBySlug(ongoingSlugs);
const plannedProjects = projects
  .filter((project) => !completedSlugs.includes(project.slug) && !ongoingSlugs.includes(project.slug))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<section class="projects" id="projects">
  <div class="projects__inner">
    <p class="projects__eyebrow">Case Studies</p>
    <h2 class="projects__title">Projects</h2>

    <div class="projects__section">
      <h3 class="projects__category-title">Active Projects</h3>
      <p class="projects__section-note">Production-like and actively maintained portfolio projects.</p>
      <div class="projects__grid">
        {completedProjects.map((project) => {
          const isFlagship = project.slug === 'cyberops-portal-securitypulse';

          return (
            <article class:list={['project-card', isFlagship && 'project-card--flagship']}>
              {isFlagship && <p class="project-card__badge">Flagship Project</p>}
              <h4 class="project-card__title">
                <a class="project-card__title-link" href={`/projects/${project.slug}`}>{project.data.title}</a>
              </h4>
              <p class="project-card__description">{project.data.description}</p>
              <ul class="project-card__tags" aria-label="Tech stack">
                {project.data.stack.map((tag) => <li>{tag}</li>)}
              </ul>
              <a class="project-card__link" href={`/projects/${project.slug}`}>Open Project</a>
            </article>
          );
        })}
      </div>
    </div>

    <div class="projects__section">
      <h3 class="projects__category-title">Ongoing</h3>
      <p class="projects__section-note">Currently in progress and being expanded.</p>
      <div class="projects__grid">
        {ongoingProjects.map((project) => (
          <article class="project-card">
            <p class="project-card__badge">In Progress</p>
            <h4 class="project-card__title">
              <a class="project-card__title-link" href={`/projects/${project.slug}`}>{project.data.title}</a>
            </h4>
            <p class="project-card__description">{project.data.description}</p>
            <ul class="project-card__tags" aria-label="Tech stack">
              {project.data.stack.map((tag) => <li>{tag}</li>)}
            </ul>
            <a class="project-card__link" href={`/projects/${project.slug}`}>Open Project</a>
          </article>
        ))}
      </div>
    </div>

    <div class="projects__section">
      <h3 class="projects__category-title">Planned (Not Started Yet)</h3>
      <p class="projects__section-note">Planned roadmap items for upcoming implementation.</p>
      <div class="projects__grid">
        {plannedProjects.map((project) => (
          <article class="project-card project-card--planned">
            <p class="project-card__badge project-card__badge--planned">Planned</p>
            <h4 class="project-card__title">
              <a class="project-card__title-link" href={`/projects/${project.slug}`}>{project.data.title}</a>
            </h4>
            <p class="project-card__description">{project.data.description}</p>
            <ul class="project-card__tags" aria-label="Tech stack">
              {project.data.stack.map((tag) => <li>{tag}</li>)}
            </ul>
            <a class="project-card__link" href={`/projects/${project.slug}`}>Open Project</a>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .projects {
    padding: 5rem 1.5rem;
    background:
      radial-gradient(circle at 82% 12%, rgba(6, 182, 212, 0.16), transparent 35%),
      radial-gradient(circle at 10% 88%, rgba(16, 185, 129, 0.12), transparent 35%),
      linear-gradient(150deg, #02070d 0%, #070f17 45%, #02070d 100%);
    color: #e2e8f0;
  }

  .projects__inner {
    max-width: 1360px;
    margin: 0 auto;
  }

  .projects__eyebrow {
    display: inline-block;
    margin: 0 0 1rem;
    padding: 0.35rem 0.8rem;
    border: 1px solid rgba(20, 184, 166, 0.45);
    border-radius: 999px;
    color: #5eead4;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.75rem;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
  }

  .projects__title {
    margin: 0 0 1.5rem;
    font-size: clamp(1.9rem, 4.2vw, 2.9rem);
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
    color: #f8fafc;
    letter-spacing: -0.02em;
  }

  .projects__section {
    margin-top: 1.7rem;
  }

  .projects__category-title {
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.28);
    color: #67e8f9;
    font-size: 1.08rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
  }

  .projects__section-note {
    margin: 0 0 1rem;
    color: #9fb0bf;
    font-size: 0.95rem;
    font-family: "Inter", "Segoe UI", system-ui, -apple-system, sans-serif;
  }

  .projects__grid {
    display: grid;
    gap: 1.2rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .project-card {
    border: 1px solid rgba(100, 116, 139, 0.35);
    border-radius: 0.9rem;
    background: rgba(2, 6, 12, 0.65);
    backdrop-filter: blur(2px);
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    min-height: 100%;
    transition: transform 140ms ease, border-color 140ms ease, box-shadow 140ms ease;
  }

  .project-card--flagship {
    border-color: rgba(20, 184, 166, 0.55);
    box-shadow: inset 0 0 0 1px rgba(20, 184, 166, 0.25), 0 16px 34px rgba(2, 8, 20, 0.5);
    background:
      radial-gradient(circle at 92% 8%, rgba(6, 182, 212, 0.2), transparent 28%),
      rgba(2, 6, 12, 0.82);
  }

  .project-card--planned {
    border-style: dashed;
    border-color: rgba(148, 163, 184, 0.45);
  }

  .project-card:hover,
  .project-card:focus-within {
    transform: translateY(-3px);
    border-color: rgba(34, 211, 238, 0.55);
    box-shadow: 0 12px 28px rgba(3, 7, 18, 0.45);
  }

  .project-card__badge {
    margin: 0 0 0.65rem;
    color: #99f6e4;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
  }

  .project-card__badge--planned {
    color: #cbd5e1;
  }

  .project-card__title {
    margin: 0 0 0.75rem;
    font-size: 1.15rem;
    line-height: 1.25;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
  }

  .project-card__title-link {
    color: #e2e8f0;
    text-decoration: none;
    font-weight: 700;
    transition: color 140ms ease, font-weight 140ms ease;
  }

  .project-card:hover .project-card__title-link,
  .project-card:focus-within .project-card__title-link,
  .project-card__title-link:hover,
  .project-card__title-link:focus-visible {
    color: #f8fafc;
    font-weight: 800;
  }

  .project-card__description {
    margin: 0;
    flex: 1;
    color: #9ca3af;
    line-height: 1.55;
    font-size: 0.98rem;
    font-family: "Inter", "Segoe UI", system-ui, -apple-system, sans-serif;
  }

  .project-card__tags {
    list-style: none;
    margin: 1rem 0;
    padding: 0;
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .project-card__tags li {
    font-size: 0.75rem;
    border: 1px solid rgba(56, 189, 248, 0.35);
    color: #67e8f9;
    border-radius: 999px;
    padding: 0.25rem 0.65rem;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
  }

  .project-card__link {
    margin-top: auto;
    align-self: flex-start;
    text-decoration: none;
    padding: 0.62rem 1rem;
    border-radius: 0.55rem;
    border: 1px solid rgba(45, 212, 191, 0.45);
    color: #ecfeff;
    background: rgba(6, 182, 212, 0.12);
    font-size: 0.86rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
    transition: transform 140ms ease, border-color 140ms ease, background 140ms ease;
  }

  .project-card__link:hover,
  .project-card__link:focus-visible {
    transform: translateY(-2px);
    border-color: #7dd3fc;
    background: rgba(125, 211, 252, 0.2);
  }

  @media (min-width: 1000px) {
    .project-card--flagship {
      grid-column: span 2;
    }
  }

  @media (max-width: 980px) {
    .projects__inner {
      margin: 0 auto;
      padding-right: 0;
    }
  }

  @media (max-width: 640px) {
    .projects {
      padding-top: 3.5rem;
      padding-bottom: 3.5rem;
    }

    .project-card {
      padding: 1rem;
    }
  }
</style>
