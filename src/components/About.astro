---
---

<section class="about" id="about">
  <div class="about__inner">
    <p class="about__eyebrow">Profile</p>
    <h2 class="about__title">About Me</h2>
    <p class="about__text">
      I am Zdravko Panov, a System Administrator and DevOps specialist focused on building reliable monitoring,
      observability, and automation solutions across Windows and Linux environments.
    </p>
    <p class="about__text">
      I work with Prometheus, Grafana, PowerShell, Bash scripting, VMware products, and Docker to deliver stable systems,
      faster troubleshooting, and repeatable operations in production-ready infrastructure.
    </p>

    <div class="about__meta">
      <div class="about__meta-item">
        <span class="about__meta-label">Location</span>
        <span class="about__meta-value">Bulgaria</span>
      </div>
      <div class="about__meta-item">
        <span class="about__meta-label">Role</span>
        <span class="about__meta-value">System Administrator | DevOps</span>
      </div>
      <div class="about__meta-item">
        <span class="about__meta-label">Focus</span>
        <span class="about__meta-value">Monitoring, Linux Administration, Automation, Observability</span>
      </div>
    </div>

    <div class="about__links">
      <a href="https://github.com/ZdravecPanov/zdravkopanov-online" target="_blank" rel="noopener noreferrer">GitHub Repo</a>
      <a href="/cv/Zdravko_Panov_Resume.pdf" download="Zdravko_Panov_Resume.pdf">Download CV</a>
      <a href="mailto:zdravko.panov@gmail.com">Contact</a>
    </div>
  </div>
</section>

<style>
  .about {
    padding: 0.8rem 1.5rem 1rem calc(clamp(1rem, 7vw, 6rem) + 1.5rem);
    background:
      radial-gradient(circle at 84% 22%, rgba(6, 182, 212, 0.12), transparent 35%),
      linear-gradient(160deg, #030b12 0%, #03101a 55%, #02070d 100%);
    color: #dbe4ee;
  }

  .about__inner {
    width: 100%;
    max-width: none;
    margin: 0;
    border: 1px solid rgba(100, 116, 139, 0.28);
    background: rgba(2, 6, 12, 0.52);
    border-radius: 1rem;
    padding: 1.25rem;
  }

  .about__eyebrow {
    display: inline-block;
    margin: 0 0 0.8rem;
    padding: 0.3rem 0.75rem;
    border: 1px solid rgba(20, 184, 166, 0.45);
    border-radius: 999px;
    color: #5eead4;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.72rem;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
  }

  .about__title {
    margin: 0 0 0.8rem;
    color: #f8fafc;
    font-size: clamp(1.45rem, 2.8vw, 2rem);
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
    letter-spacing: -0.02em;
  }

  .about__text {
    margin: 0 0 0.7rem;
    color: #a8b4c2;
    max-width: 84ch;
    line-height: 1.62;
    font-size: 0.98rem;
    font-family: "Inter", "Segoe UI", system-ui, -apple-system, sans-serif;
  }

  .about__meta {
    margin-top: 1rem;
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
  }

  .about__meta-item {
    border: 1px solid rgba(71, 85, 105, 0.45);
    border-radius: 0.75rem;
    background: rgba(2, 8, 20, 0.62);
    padding: 0.7rem 0.8rem;
  }

  .about__meta-label {
    display: block;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #5eead4;
    margin-bottom: 0.32rem;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
  }

  .about__meta-value {
    color: #dbe4ee;
    line-height: 1.45;
    font-size: 0.9rem;
    font-family: "Inter", "Segoe UI", system-ui, -apple-system, sans-serif;
  }

  .about__links {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .about__links a {
    text-decoration: none;
    color: #ecfeff;
    border: 1px solid rgba(45, 212, 191, 0.45);
    border-radius: 0.55rem;
    background: rgba(6, 182, 212, 0.12);
    padding: 0.48rem 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.76rem;
    font-family: "IBM Plex Mono", "JetBrains Mono", "Fira Mono", Consolas, monospace;
  }

  @media (max-width: 980px) {
    .about {
      padding: 0.8rem 1rem 1rem;
    }

    .about__inner {
      width: 100%;
    }
  }
</style>
